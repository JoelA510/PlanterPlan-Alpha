{
  "name": "planterplan-alpha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:agent": "node scripts/tsc-agent.cjs",
    "db:local:bootstrap": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:bootstrap:fresh": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:test": "npm run db:local:bootstrap && npx --no-install supabase test db",
    "db:local:test:fresh": "npm run db:local:bootstrap:fresh && npx --no-install supabase test db",
    "verify-dependencies": "node scripts/verify-dependency-guardrails.cjs",
    "verify-architecture": "node scripts/verify-architecture.cjs",
    "verify-e2e": "bash scripts/verify-e2e.sh",
    "test:e2e": "node scripts/run-e2e.cjs",
    "test:e2e:release": "node scripts/run-e2e.cjs --grep @release",
    "test:e2e:mobile": "node scripts/run-e2e.cjs --project=mobile-chrome",
    "test:e2e:headed": "node scripts/run-e2e.cjs --headed",
    "test:e2e:vision": "node scripts/run-e2e.cjs --grep @vision",
    "test:e2e:a11y": "node scripts/run-e2e.cjs --project=accessibility",
    "lint": "eslint .",
    "test": "vitest --run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "gantt-task-react": "0.3.9",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.8",
    "react-is": "19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright-bdd": "^8.5.1",
    "supabase": "2.98.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@cucumber/messages@27.2.0": {
      "uuid": "11.1.1"
    }
  }
}
