{
  "name": "temp-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:agent": "node scripts/tsc-agent.cjs",
    "verify-architecture": "bash scripts/verify-architecture.sh",
    "verify-e2e": "bash scripts/verify-e2e.sh",
    "test:e2e": "npx bddgen --config e2e/playwright.config.ts && npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:mobile": "npx bddgen --config e2e/playwright.config.ts && npx playwright test --config e2e/playwright.config.ts --project=mobile-chrome",
    "test:e2e:headed": "npx bddgen --config e2e/playwright.config.ts && npx playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:vision": "npx bddgen --config e2e/playwright.config.ts && GEMINI_API_KEY=${GEMINI_API_KEY} npx playwright test --config e2e/playwright.config.ts --grep @vision",
    "test:e2e:a11y": "npx bddgen --config e2e/playwright.config.ts && npx playwright test --config e2e/playwright.config.ts --project=accessibility",
    "lint": "eslint .",
    "test": "vitest --run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/supabase-js": "^2.96.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.574.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.13.2",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "playwright-bdd": "^8.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
